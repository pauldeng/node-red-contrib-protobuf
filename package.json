{
  "name": "node-red-contrib-protobuf",
  "version": "1.1.2",
  "description": "Protocol buffer encode/decode nodes.",
  "type": "commonjs",
  "main": "src/index.js",
  "files": [
    "src",
    "examples",
    "README.md",
    "LICENCE"
  ],
  "scripts": {
    "test": "mocha \"test/**/*spec.js\"",
    "test:ui": "playwright test",
    "coverage": "nyc --reporter=text --reporter=lcov npm test",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pauldeng/node-red-contrib-protobuf.git"
  },
  "keywords": [
    "node-red",
    "protobuf"
  ],
  "author": "Alexander Wellbrock <a.wellbrock@mailbox.org>",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/pauldeng/node-red-contrib-protobuf/issues"
  },
  "homepage": "https://github.com/pauldeng/node-red-contrib-protobuf#README",
  "engines": {
    "node": ">=18.5"
  },
  "node-red": {
    "version": ">=4.1.0",
    "nodes": {
      "encode": "src/nodes/encode.js",
      "decode": "src/nodes/decode.js",
      "file": "src/nodes/protofile.js"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "eslint": "^9.39.4",
    "mocha": "^11.7.6",
    "node-red": "^4.1.11",
    "node-red-node-test-helper": "^0.3.6",
    "nyc": "^17.1.0"
  },
  "dependencies": {
    "protobufjs": "^8.6.1"
  }

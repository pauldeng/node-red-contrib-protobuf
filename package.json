{
  "name": "@pauldeng/node-red-contrib-protobuf",
  "version": "2.0.2",
  "description": "Node-RED nodes for encoding and decoding Protocol Buffers.",
  "type": "commonjs",
  "main": "src/index.js",
  "files": [
    "src",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "mocha \"test/**/*spec.js\" --ignore \"test/ui/**/*.spec.js\"",
    "test:ui": "playwright test",
    "coverage": "nyc --reporter=text --reporter=lcov npm test",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "test:docker": "node scripts/run-docker-tests.js",
    "update:protobufjs-fixtures": "node scripts/update-protobufjs-fixtures.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pauldeng/node-red-contrib-protobuf.git"
  },
  "keywords": [
    "node-red",
    "node-red-contrib",
    "protobuf",
    "protocol-buffers",
    "protobufjs",
    "proto3",
    "proto2",
    "encode",
    "decode",
    "iot"
  ],
  "author": "Paul Deng <paul.deng@gallagher.com>",
  "contributors": [
    "Alexander Wellbrock <a.wellbrock@mailbox.org> (original author)"
  ],
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/pauldeng/node-red-contrib-protobuf/issues"
  },
  "homepage": "https://github.com/pauldeng/node-red-contrib-protobuf#README",
  "engines": {
    "node": ">=20.19.0"
  },
  "node-red": {
    "version": ">=4.1.0",
    "nodes": {
      "encode": "src/nodes/encode.js",
      "decode": "src/nodes/decode.js",
      "file": "src/nodes/protofile.js"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "mocha": "^11.7.6",
    "node-red": "^5.0.1",
    "node-red-node-test-helper": "^0.3.6",
    "nyc": "^18.0.0"
  },
  "dependencies": {
    "protobufjs": "^8.7.0"
  }
}
